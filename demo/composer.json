{
    "name": "tacman/ai-batch-demo",
    "description": "Demo app: programmer-targeted ad copy for dummyjson products, sync vs batch",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^8.0",
        "symfony/console": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/dotenv": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/scheduler": "^8.0",
        "symfony/messenger": "^8.0",
        "doctrine/orm": "^3.0",
        "doctrine/dbal": "^4.0",
        "tacman/ai-batch": "*"
    },
    "autoload": {
        "psr-4": { "App\\": "src/" }
    },
    "repositories": [
        {"type": "path", "url": ".."}
    ],
    "scripts": {
        "post-install-cmd": [
            "@php bin/console doctrine:schema:update --force --no-interaction"
        ]
    }
}
